		<script>
			// Theme Management
			const themeToggle = document.getElementById("theme-toggle");
			const html = document.documentElement;

			// Check for saved theme or system preference
			const savedTheme = localStorage.getItem("theme");
			const systemDark = window.matchMedia(
				"(prefers-color-scheme: dark)",
			).matches;

			if (savedTheme === "dark" || (!savedTheme && systemDark)) {
				html.classList.add("dark");
			} else {
				html.classList.remove("dark");
				if (savedTheme === "light") html.classList.add("light");
			}

			themeToggle?.addEventListener("click", () => {
				if (html.classList.contains("dark")) {
					html.classList.remove("dark");
					html.classList.add("light");
					localStorage.setItem("theme", "light");
				} else {
					html.classList.remove("light");
					html.classList.add("dark");
					localStorage.setItem("theme", "dark");
				}
			});

			// Navbar Scroll Effect
			const navbar = document.getElementById("navbar");
			window.addEventListener("scroll", () => {
				if (navbar) {
					if (window.scrollY > 50) {
						navbar.classList.add("scrolled");
					} else {
						navbar.classList.remove("scrolled");
					}
				}
			});

			// Reveal on scroll logic for store cards
			const observerOptions = {
				threshold: 0.1,
			};

			const observer = new IntersectionObserver((entries) => {
				entries.forEach((entry) => {
					if (entry.isIntersecting) {
						(entry.target as HTMLElement).style.opacity = "1";
						(entry.target as HTMLElement).style.transform =
							"translateY(0)";
						observer.unobserve(entry.target);
					}
				});
			}, observerOptions);

			document.querySelectorAll(".store-card").forEach((card) => {
				(card as HTMLElement).style.opacity = "0";
				(card as HTMLElement).style.transform = "translateY(40px)";
				observer.observe(card);
			});

			// Promo Carousel Logic
			const promoTrack = document.querySelector(".carousel-track") as HTMLElement;
			const promoDots = document.querySelectorAll(".dot");
			const promoContainer = document.getElementById("promo-carousel");
			let promoIndex = 0;
			const totalPromos = promoDots.length;

			function updatePromoCarousel() {
				if (!promoTrack) return;
				promoTrack.style.transform = `translateX(-${promoIndex * 100}%)`;
				promoDots.forEach((dot, i) => {
					dot.classList.toggle("active", i === promoIndex);
				});
			}

			function nextPromo() {
				promoIndex = (promoIndex + 1) % totalPromos;
				updatePromoCarousel();
			}

			let promoInterval = setInterval(nextPromo, 5000);

			if (promoContainer) {
				promoContainer.addEventListener("mouseenter", () =>
					clearInterval(promoInterval),
				);
				promoContainer.addEventListener("mouseleave", () => {
					clearInterval(promoInterval);
					promoInterval = setInterval(nextPromo, 5000);
				});

				promoDots.forEach((dot, i) => {
					dot.addEventListener("click", () => {
						promoIndex = i;
						updatePromoCarousel();
						clearInterval(promoInterval);
						promoInterval = setInterval(nextPromo, 5000);
					});
				});
			}
		</script>
